@Article{en14051232,
AUTHOR = {Giernacki, Wojciech and Gośliński, Jarosław and Goślińska, Jagoda and Espinoza-Fraire, Tadeo and Rao, Jinjun},
TITLE = {Mathematical Modeling of the Coaxial Quadrotor Dynamics for Its Attitude and Altitude Control},
JOURNAL = {Energies},
VOLUME = {14},
YEAR = {2021},
NUMBER = {5},
ARTICLE-NUMBER = {1232},
URL = {https://www.mdpi.com/1996-1073/14/5/1232},
ISSN = {1996-1073},
ABSTRACT = {In this paper, an easily implementable coaxial quadrotor model and its validation on data from a real unmanned aerial vehicle (UAV), are presented. The proposed mathematical model consists of two parts: description of orientation and position of the UAV in the three-dimensional space. It takes into consideration the gyroscopic effect, influence of the Coriolis force, viscous friction and a several drag-like effects (blade flapping, rotor drag, translational drag and profile drag). In contrast to multirotor models available in the literature, this one is characterized by complementarity in relation to the available control techniques. Depending on selection of these techniques, the model can be narrowed (simplified) to meet the needs without the loss of behaviour adequacy to a real UAV.},
DOI = {10.3390/en14051232}
}
